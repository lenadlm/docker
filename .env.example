# ============================================================
# Leo's Homelab — Configuration Template
# Copy this to .env and fill in your values.
# ============================================================

# --- Telegram Notifications ---
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id

# --- Home Assistant ---
HA_HOST=192.168.1.123
HA_PORT=8123
HA_LONG_LIVED_TOKEN=your_ha_long_lived_token

# --- Proxmox ---
PROXMOX_HOST=192.168.1.55
PROXMOX_TOKEN_ID=root@pam!your_token_name

# --- Docker Host ---
DOCKER_HOST=192.168.1.220
DOCKER_USER=leo
DOCKER_STACK_DIR=/mnt/shared/tmp/docker
HERMES_HOST=192.168.1.222

# --- Docker Networks ---
DOCKER_INTERNAL_SUBNET=172.30.0.0/24
DOCKER_INTERNAL_GW=172.30.0.1
DOCKER_EXTERNAL_SUBNET=172.20.0.0/24
DOCKER_EXTERNAL_GW=172.20.0.1
INTERNAL_NETWORK_GATEWAY=172.30.0.1

# --- Static Docker IPs ---
PLEX_IP=172.30.0.32
PORTAINER_IP=172.30.0.10
N8N_HOST_IP=192.168.1.220
HOMEPAGE_HOST=192.168.1.197:3300

# --- Tailscale ---
TAILSCALE_DOCKER=100.70.60.220
TAILSCALE_HERMES=100.70.60.222
TAILSCALE_HA=100.70.60.123
TAILSCALE_DOMAIN=your-tailscale-domain.ts.net
TAILSCALE_SRV=100.70.60.70

# --- Transmission ---
TRANSMISSION_PASS=change_me