[DEFAULT]
backend         = auto
banaction       = crowdsec
banaction_allports = crowdsec
action          = crowdsec
loglevel        = INFO
logtarget       = /var/log/fail2ban.log
maxretry        = 2
findtime        = 12h
bantime         = 7d
bantime.increment = true
bantime.factor  = 2
bantime.rndtime = 2d
bantime.maxtime = 90d

[sshd]
enabled    = true
filter     = sshd
port       = ssh
mode       = aggressive
backend    = polling
logpath    = /var/log/auth.log
